# Environment variables for PerfMemory MCP
########################################
# 🧠 PerfMemory MCP - Environment Config
########################################

# --------------------------------------
# 🔀 Embedding Provider Selection
# --------------------------------------
# Options: openai | azure_openai | ollama
EMBEDDING_PROVIDER=openai

# --------------------------------------
# 🤖 OpenAI Configuration
# --------------------------------------
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --------------------------------------
# ☁️ Azure OpenAI Configuration
# --------------------------------------
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# --------------------------------------
# 🏠 Ollama Configuration (Local)
# --------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --------------------------------------
# 🗄️ PostgreSQL / pgvector Configuration
# --------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=perfmemory
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# SSL mode for database connections.
# Local Docker: prefer (default) or disable
# Azure/AWS/GCP: require, verify-ca, or verify-full
POSTGRES_SSLMODE=prefer

# Path to the CA root certificate (required for verify-ca / verify-full).
# Azure:  DigiCert Global Root G2  (https://learn.microsoft.com/en-us/azure/postgresql/flexible-server/concepts-networking-ssl-tls)
# AWS:    Amazon RDS CA bundle     (https://docs.aws.amazon.com/AmazonRDS/latest/UserGuide/UsingWithRDS.SSL.html)
# GCP:    Cloud SQL server CA      (https://cloud.google.com/sql/docs/postgres/configure-ssl-instance)
POSTGRES_SSLROOTCERT=

# --------------------------------------
# ⚙️ Optional Settings
# --------------------------------------
# Toggle debug logging
DEBUG=true

# Control max results returned from vector search
VECTOR_TOP_K=5

# Similarity threshold (0.0 - 1.0, cosine similarity)
SIMILARITY_THRESHOLD=0.75