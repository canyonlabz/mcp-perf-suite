# Environment variables for PerfPilot Agents (agent-framework/)
########################################
# 🤖 PerfPilot Agents - Environment Config
########################################
#
# This is the development template. Copy to `.env` and fill in real values.
# `.env` is gitignored. No real credentials belong in this file.
#
# For Docker deployment, the equivalent file lives at `docker/.env.a2a`
# (created in Feature 3.12). Variable names are identical so the same values
# work in both contexts.

# --------------------------------------
# 🌐 LLM Provider - Global Fallback
# --------------------------------------
# Default provider used when an agent's config.yaml does not declare its own.
# Per-agent overrides live in agents/<name>/config.yaml.
# Options: openai | azure_openai | ollama
LLM_PROVIDER=openai

# --------------------------------------
# 🤖 OpenAI Configuration
# --------------------------------------
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# --------------------------------------
# ☁️ Azure OpenAI Configuration
# --------------------------------------
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# --------------------------------------
# 🏠 Ollama Configuration (Local)
# --------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --------------------------------------
# 🔒 TLS / Corporate CA bundle
# --------------------------------------
# Path to a PEM file containing the CA chain that should be trusted for
# outbound HTTPS calls (OpenAI, Azure OpenAI, MCP gateways). Required when
# your machine sits behind a TLS-inspecting proxy or anti-virus product
# (Norton 360, Zscaler, BlueCoat, ...). Same convention as the MCP servers:
# blazemeter-mcp, datadog-mcp, confluence-mcp.
#
# When unset, Python's default trust store (certifi) is used. The
# `ssl_verification` field in `config/agents.yaml` controls how these vars
# are honored:
#   ca_bundle (default) -> use the bundle below if set, else certifi.
#   system              -> always use certifi, ignore the bundle.
#   disabled            -> skip TLS verification entirely (lab use only).
#
# Set BOTH variables to the same path for compatibility with the openai SDK
# (which reads SSL_CERT_FILE) and httpx-based clients (which read
# REQUESTS_CA_BUNDLE first).
SSL_CERT_FILE=
REQUESTS_CA_BUNDLE=

# --------------------------------------
# 🗄️ perfagent_state Database (PostgreSQL on the same instance as perfmemory)
# --------------------------------------
# In Epic 3 testing, both perfmemory and perfagent_state may share credentials
# for convenience. Plan for separate users in Epic 4 (perfmemory_user vs
# perfagent_state_user) for least-privilege access control with EntraID.
PERFAGENT_STATE_HOST=localhost
PERFAGENT_STATE_PORT=5432
PERFAGENT_STATE_DB=perfagent_state
PERFAGENT_STATE_USER=postgres
PERFAGENT_STATE_PASSWORD=your_password_here

# SSL mode for database connections.
# Local Docker: prefer (default) or disable
# Azure / AWS / GCP: require, verify-ca, or verify-full
PERFAGENT_STATE_SSLMODE=prefer

# Optional: path to CA root certificate for verify-ca / verify-full.
PERFAGENT_STATE_SSLROOTCERT=

# --------------------------------------
# 🌍 PerfPilot Hub Gateway (MCP)
# --------------------------------------
# Where the agents reach the gateway-mcp HTTP server. Inside Docker compose
# this becomes http://perf-gateway:8000/mcp; for local-host runs use the
# loopback URL below.
GATEWAY_MCP_URL=http://localhost:8000/mcp

# --------------------------------------
# 🎭 Microsoft Playwright MCP (Container 4)
# --------------------------------------
# Used by the script-agent only. Inside Docker compose this becomes
# http://playwright-mcp:8003/mcp.
PLAYWRIGHT_MCP_URL=http://localhost:8003/mcp

# --------------------------------------
# 🔌 Server Ports
# --------------------------------------
A2A_PORT=8001
AGUI_PORT=8002

# --------------------------------------
# 🔐 Auth (Epic 4 readiness; default disabled)
# --------------------------------------
# When true, the auth middleware in utils/auth.py runs the configured
# identity provider check. Epic 3 keeps this off; Epic 4 wires it to EntraID.
AUTH_ENABLED=false

# --------------------------------------
# 📊 OpenTelemetry (Epic 4 readiness; default disabled)
# --------------------------------------
# When enabled, span hooks in utils/otel.py route session_id, task_id, and
# external_session_id (Section 4.3 of the V2 doc) into OTLP spans.
OTEL_ENABLED=false
OTEL_EXPORTER_ENDPOINT=
OTEL_SERVICE_NAME=perfpilot-agents

# --------------------------------------
# ⚙️ Notes
# --------------------------------------
# Per-agent settings (LLM provider override, allowed MCP namespaces, retries,
# timeouts) live in each agent's config.yaml under agents/<agent-name>/.
# Global agent enable/disable flags live in config/agents.yaml.
