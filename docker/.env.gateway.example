# =============================================================================
# PerfPilot Hub — Docker Gateway Environment Variables
# =============================================================================
# Copy this file to .env.gateway and fill in your values:
#   cp .env.gateway.example .env.gateway  (Linux/macOS)
#   Copy-Item .env.gateway.example .env.gateway  (Windows PowerShell)
#
# This file is referenced by docker-compose-gateway-*.yaml and
# docker-compose-full-*.yaml via env_file directive.
# =============================================================================

# =============================================================================
# Gateway Configuration (defaults set in Dockerfile — override here if needed)
# =============================================================================
# PERFPILOT_DOCKER=true
# GATEWAY_TRANSPORT=http
# GATEWAY_PORT=8000

# =============================================================================
# BlazeMeter MCP
# =============================================================================
# API credentials from https://a.blazemeter.com/app/#/account/profile
BLAZEMETER_API_KEY=your_blazemeter_api_key
BLAZEMETER_API_SECRET=your_blazemeter_api_secret
BLAZEMETER_ACCOUNT_ID=your_blazemeter_account_id
BLAZEMETER_WORKSPACE_ID=your_blazemeter_workspace_id

# =============================================================================
# Datadog MCP
# =============================================================================
# API/App keys from https://app.datadoghq.com/organization-settings/api-keys
DD_API_KEY=your_datadog_api_key
DD_APP_KEY=your_datadog_app_key
# Base URL — change for EU site (https://api.datadoghq.eu) or other regions
DD_API_BASE_URL=https://api.datadoghq.com

# =============================================================================
# Confluence MCP — Cloud (v2 API)
# =============================================================================
# Only required if using Confluence Cloud
CONFLUENCE_V2_BASE_URL=https://your-site.atlassian.net/wiki
CONFLUENCE_V2_USER=your.email@company.com
CONFLUENCE_V2_API_TOKEN=your_cloud_api_token

# =============================================================================
# Confluence MCP — On-Premises (v1 API)
# =============================================================================
# Only required if using Confluence Data Center / Server
CONFLUENCE_V1_BASE_URL=https://your-onprem-host
CONFLUENCE_V1_PAT=your_personal_access_token
CONFLUENCE_V1_USER=your.username

# =============================================================================
# PerfMemory MCP — Embedding Provider
# =============================================================================
# Options: openai | azure_openai | ollama
EMBEDDING_PROVIDER=openai

# --- OpenAI Configuration ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Azure OpenAI Configuration (if EMBEDDING_PROVIDER=azure_openai) ---
# AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
# AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=text-embedding-3-small
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# --- Ollama Configuration (if EMBEDDING_PROVIDER=ollama) ---
# Note: When running in Docker, use host.docker.internal instead of localhost
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# =============================================================================
# PerfMemory MCP — PostgreSQL / pgvector
# =============================================================================
# When using docker-compose-full-*.yaml, POSTGRES_HOST should be "perfmemory-db"
# (the Docker Compose service name). For external databases, use the hostname/IP.
POSTGRES_HOST=perfmemory-db
POSTGRES_PORT=5432
POSTGRES_DB=perfmemory
POSTGRES_USER=perfadmin
POSTGRES_PASSWORD=your_secure_password_here

# SSL mode for database connections
# Local Docker: prefer (default) or disable
# Azure/AWS/GCP: require, verify-ca, or verify-full
POSTGRES_SSLMODE=prefer

# Path to CA root certificate (required for verify-ca / verify-full)
# POSTGRES_SSLROOTCERT=

# =============================================================================
# JMeter MCP — TLS Client Certificates (Optional)
# =============================================================================
# For corporate environments using JKS keystores for client authentication.
# Both variables MUST be set together — the entrypoint script skips keystore
# configuration if only one is provided.
# Place the .jks file in docker/certs/jmeter/ before building.
# JMETER_JKS_FILE=your-keystore.jks
# JMETER_JKS_PWD=your_keystore_password

# =============================================================================
# JMeter MCP — Properties (Optional)
# =============================================================================
# Set to "true" to enable CookieManager.save.cookies=true in jmeter.properties
# JMETER_COOKIE_SAVE=false
